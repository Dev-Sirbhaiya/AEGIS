# ============================================================
# AEGIS Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- LLM PROVIDER (choose ONE, set its API key) ---
# Options: claude | openai | groq | ollama
LLM_PROVIDER=

# Provider API Keys (set the one matching LLM_PROVIDER)
GROQ_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=

# For Ollama (local LLM): set this to your Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434/v1
# Ollama model to use (e.g., llama3.1:8b, mistral:7b)
OLLAMA_MODEL=llama3.1:8b

# --- LLM Model Selection ---
# These are the default models per provider. Override if needed.
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
GROQ_MODEL=llama-3.3-70b-versatile

# --- DATABASE ---
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_password
DATABASE_URL=postgresql+asyncpg://aegis:aegis_dev_password@localhost:5432/aegis

# --- REDIS ---
REDIS_URL=redis://localhost:6379/0

# --- AUTHENTICATION ---
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# --- AI MODEL SETTINGS ---
# Anomalib model: efficient_ad | patchcore | padim | stfpm
ANOMALIB_MODEL=efficient_ad
# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# Video processing: frames per second to analyze
VIDEO_FPS=2
# Anomaly score threshold (0.0 to 1.0). Events above this trigger alerts.
ANOMALY_THRESHOLD=0.5

# --- VOICE AGENT ---
# TTS engine: edge_tts | kokoro
TTS_ENGINE=edge_tts
# Default language for voice agent
VOICE_AGENT_LANGUAGE=en
# Edge TTS voice name (see: edge-tts --list-voices)
TTS_VOICE_EDGE=en-US-GuyNeural
# Kokoro voice and speed (used when TTS_ENGINE=kokoro)
TTS_VOICE_KOKORO=af_heart
TTS_VOICE_SPEED=1.0
TTS_SAMPLE_RATE=24000
# Urgency score (0.0-1.0) above which voice agent raises SOC alert
VOICE_URGENCY_THRESHOLD=0.6

# --- INTELLIGENCE ---
# Sentence-transformers model for RAG embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Groq API base URL (change only if using a proxy)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- PATHS (relative to project root) ---
DATA_DIR=./data
MODELS_DIR=./models

# --- SERVER ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
